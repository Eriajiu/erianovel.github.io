datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  AUTHOR
  ADMIN
}

enum NovelStatus {
  ONGOING
  COMPLETED
  PAUSED
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String           @unique
  emailVerified DateTime?
  image         String?          @default("https://images.unsplash.com/photo-1535713875002-d1d0cf377fde")
  password      String?
  role          Role             @default(USER)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  novels        Novel[]          @relation("AuthorNovels")
  bookmarks     Bookmark[]
  comments      Comment[]
  ratings       Rating[]
  history       ReadingHistory[]
}

model Novel {
  id          String           @id @default(cuid())
  title       String
  slug        String           @unique
  summary     String           @db.Text
  coverImage  String
  status      NovelStatus      @default(ONGOING)
  views       Int              @default(0)
  authorId    String
  author      User             @relation("AuthorNovels", fields: [authorId], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  chapters    Chapter[]
  bookmarks   Bookmark[]
  comments    Comment[]
  ratings     Rating[]
  history     ReadingHistory[]
  genres      Genre[]          @relation("NovelToGenre")

  @@index([authorId])
  @@index([views(sort: Desc)])
}

model Chapter {
  id        String           @id @default(cuid())
  novelId   String
  novel     Novel            @relation(fields: [novelId], onDelete: Cascade)
  title     String
  content   String           @db.Text
  chapterNo Int
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  history   ReadingHistory[]

  @@unique([novelId, chapterNo])
  @@index([novelId])
}

model Genre {
  id      String  @id @default(cuid())
  name    String  @unique
  slug    String  @unique
  novels  Novel[] @relation("NovelToGenre")
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], onDelete: Cascade)
  novelId   String
  novel     Novel    @relation(fields: [novelId], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, novelId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], onDelete: Cascade)
  novelId   String
  novel     Novel    @relation(fields: [novelId], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([novelId])
}

model Rating {
  id        String   @id @default(cuid())
  value     Int
  userId    String
  user      User     @relation(fields: [userId], onDelete: Cascade)
  novelId   String
  novel     Novel    @relation(fields: [novelId], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, novelId])
}

model ReadingHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], onDelete: Cascade)
  novelId   String
  novel     Novel    @relation(fields: [novelId], onDelete: Cascade)
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@unique([userId, novelId])
}
