datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum Role {
  USER
  AUTHOR
  ADMIN
}

enum NovelStatus {
  ONGOING
  COMPLETED
  HIATUS
}

model User {
  id            String           @id @default(cuid())
  name          String?
  email         String           @unique
  emailVerified DateTime?
  image         String?
  password      String?          // Hashed password dành cho Credentials Login
  role          Role             @default(USER)
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  
  // Relations
  novels        Novel[]          // Nếu user là Author
  comments      Comment[]
  ratings       Rating[]
  bookmarks     Bookmark[]
  history       ReadingHistory[]
}

model Novel {
  id          String       @id @default(cuid())
  title       String
  slug        String       @unique
  summary     String       @db.Text
  coverImage  String
  status      NovelStatus  @default(ONGOING)
  authorId    String
  author      User         @relation(fields: [authorId], references: [id], onDelete: Cascade)
  views       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  chapters    Chapter[]
  categories  NovelCategory[]
  bookmarks   Bookmark[]
  ratings     Rating[]
  comments    Comment[]

  @@index([slug])
  @@index([authorId])
}

model Category {
  id      String          @id @default(cuid())
  name    String          @unique
  slug    String          @unique
  novels  NovelCategory[]
}

model NovelCategory {
  novelId    String
  novel      Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  categoryId String
  category   Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@id([novelId, categoryId])
}

model Chapter {
  id          String           @id @default(cuid())
  novelId     String
  novel       Novel            @relation(fields: [novelId], references: [id], onDelete: Cascade)
  title       String
  chapterNo   Int
  content     String           @db.Text
  views       Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  history     ReadingHistory[]

  @@unique([novelId, chapterNo])
  @@index([novelId])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, novelId])
}

model Rating {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  score     Int      // Giá trị từ 1 đến 5 tinh túy
  createdAt DateTime @default(now())

  @@unique([userId, novelId])
}

model Comment {
  id        String   @id @default(cuid())
  content   String   @db.Text
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  novelId   String
  novel     Novel    @relation(fields: [novelId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([novelId])
}

model ReadingHistory {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  chapterId String
  chapter   Chapter  @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  updatedAt DateTime @updatedAt

  @@unique([userId, chapterId])
}