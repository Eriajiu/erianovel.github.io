<!DOCTYPE html>

<html class="dark" lang="vi"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&amp;family=Manrope:wght@600;700;800&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                      "secondary-fixed-dim": "#c1c9bc",
                      "on-secondary-container": "#b0b7ab",
                      "primary-container": "#b7d8b0",
                      "on-tertiary-fixed-variant": "#3e4a3b",
                      "on-surface-variant": "#c3c8be",
                      "surface-bright": "#353b34",
                      "on-tertiary-fixed": "#131e12",
                      "secondary-container": "#41493f",
                      "on-error": "#690005",
                      "tertiary-container": "#c5d3c0",
                      "surface-container-low": "#181d17",
                      "surface-container": "#1c211b",
                      "on-primary-fixed-variant": "#314d2f",
                      "primary": "#d3f5cb",
                      "surface-variant": "#31362f",
                      "on-secondary": "#2b3229",
                      "secondary-fixed": "#dde5d7",
                      "outline": "#8d9289",
                      "outline-variant": "#434840",
                      "on-tertiary": "#283326",
                      "error": "#ffb4ab",
                      "surface-container-high": "#262b25",
                      "primary-fixed": "#caecc3",
                      "on-tertiary-container": "#4f5b4c",
                      "on-error-container": "#ffdad6",
                      "inverse-on-surface": "#2d322b",
                      "background": "#10150f",
                      "surface-tint": "#afcfa8",
                      "on-secondary-fixed-variant": "#41493f",
                      "error-container": "#93000a",
                      "tertiary": "#e1efdb",
                      "surface-container-highest": "#31362f",
                      "primary-fixed-dim": "#afcfa8",
                      "on-primary-container": "#425f3f",
                      "tertiary-fixed": "#d9e7d3",
                      "surface-dim": "#10150f",
                      "inverse-surface": "#dfe4da",
                      "inverse-primary": "#496645",
                      "surface": "#10150f",
                      "on-surface": "#dfe4da",
                      "tertiary-fixed-dim": "#bdcab7",
                      "surface-container-lowest": "#0b0f0a",
                      "secondary": "#c1c9bc",
                      "on-secondary-fixed": "#171d15",
                      "on-primary-fixed": "#062107",
                      "on-primary": "#1b361b",
                      "on-background": "#dfe4da"
              },
              "borderRadius": {
                      "DEFAULT": "0.25rem",
                      "lg": "0.5rem",
                      "xl": "0.75rem",
                      "full": "9999px"
              },
              "spacing": {
                      "unit": "8px",
                      "container-max": "1200px",
                      "margin-mobile": "16px",
                      "gutter": "24px",
                      "margin-desktop": "40px"
              },
              "fontFamily": {
                      "label-sm": ["Inter"],
                      "label-md": ["Inter"],
                      "headline-lg-mobile": ["Manrope"],
                      "display": ["Manrope"],
                      "body-lg": ["Inter"],
                      "headline-md": ["Manrope"],
                      "headline-lg": ["Manrope"],
                      "body-md": ["Inter"]
              },
              "fontSize": {
                      "label-sm": ["12px", {"lineHeight": "1.2", "letterSpacing": "0.05em", "fontWeight": "600"}],
                      "label-md": ["14px", {"lineHeight": "1.4", "letterSpacing": "0.02em", "fontWeight": "500"}],
                      "headline-lg-mobile": ["24px", {"lineHeight": "1.2", "fontWeight": "600"}],
                      "display": ["48px", {"lineHeight": "1.1", "letterSpacing": "-0.02em", "fontWeight": "700"}],
                      "body-lg": ["18px", {"lineHeight": "1.6", "fontWeight": "400"}],
                      "headline-md": ["24px", {"lineHeight": "1.3", "fontWeight": "600"}],
                      "headline-lg": ["32px", {"lineHeight": "1.2", "letterSpacing": "-0.01em", "fontWeight": "600"}],
                      "body-md": ["16px", {"lineHeight": "1.6", "fontWeight": "400"}]
              }
            },
          },
        }
    </script>
<style>
        body {
            background-color: #10150f;
            color: #dfe4da;
            -webkit-font-smoothing: antialiased;
        }
        .glass-panel {
            backdrop-filter: blur(12px);
            background: rgba(36, 43, 34, 0.8);
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .input-inset {
            background-color: #0b0f0a;
            transition: all 0.2s ease;
        }
        .input-inset:focus {
            outline: none;
            border-color: #b7d8b0;
            box-shadow: 0 0 0 2px rgba(183, 216, 176, 0.1);
        }
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
<style>
    body {
      min-height: max(884px, 100dvh);
    }
  </style>
  </head>
<body class="min-h-screen flex items-center justify-center p-margin-mobile md:p-margin-desktop overflow-x-hidden">
<!-- Background Atmospheric Effect -->
<div class="fixed inset-0 z-[-1] pointer-events-none opacity-40">
<div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-[#b7d8b0] blur-[120px] rounded-full opacity-10"></div>
<div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] bg-[#425f3f] blur-[120px] rounded-full opacity-20"></div>
</div>
<!-- Main Content Grid -->
<main class="w-full max-w-[1000px] grid grid-cols-1 md:grid-cols-2 glass-panel rounded-xl overflow-hidden shadow-2xl">
<!-- Left: Branding & Visual -->
<section class="hidden md:flex flex-col justify-between p-12 bg-surface-container relative overflow-hidden">
<div class="relative z-10">
<h1 class="font-display text-display text-primary tracking-tighter mb-4">Lorebook</h1>
<p class="font-body-lg text-body-lg text-on-surface-variant max-w-[320px]">
                    Lưu trữ hành trình tri thức và những mảnh ký ức quan trọng của riêng bạn trong không gian số tĩnh lặng.
                </p>
</div>
<div class="relative z-10 mt-auto">
<div class="flex items-center gap-3">
<div class="w-10 h-10 rounded-full bg-primary-container flex items-center justify-center text-on-primary-container">
<span class="material-symbols-outlined">auto_stories</span>
</div>
<div>
<p class="font-label-md text-label-md text-primary">Dự án Thư viện số</p>
<p class="font-label-sm text-label-sm text-on-surface-variant">Phiên bản 2.4.0 • 2024</p>
</div>
</div>
</div>
<!-- Background Decorative Image -->
<div class="absolute inset-0 opacity-20 scale-110">
<img alt="Atmospheric landscape" class="w-full h-full object-cover" data-alt="A cinematic, atmospheric photography of high mountain peaks under a vast starry night sky. The scene is bathed in a deep midnight green and charcoal palette, reflecting a serene and intellectual mood. Soft moonlight catches the edges of the terrain, creating subtle highlights and a sense of profound stillness, aligning with a high-end digital archiving aesthetic." src="https://lh3.googleusercontent.com/aida-public/AB6AXuBTND1xiXkKwDbE2gr-px_ZOyq7vGgcTe9ci4Y6FLvn58Gdg5T8ZGw0n5yU2Xa0nmJYfh1g07zJCxM_YBnSxrXWQsRcxHpU_zpdiUjM1YgfsTO3iNEdOiU57fz1unlkQ4HAhEkJX7v4IUWO_ctNNg9afWZniiVetwWliHbLNsr5-M91orw3l965Qf9WAOBuIPPVetO3DDi3r9QadLRFK7DAt7eoJ2gDiCfAaFaJN-Rp9ssdzpefBzgWICEZvRtapn0NQJAQ-aqffK6X"/>
</div>
</section>
<!-- Right: Registration Form -->
<section class="p-8 md:p-12 flex flex-col justify-center bg-surface-dim">
<div class="mb-10 text-center md:text-left">
<div class="md:hidden mb-6 flex justify-center">
<span class="font-display text-headline-md text-primary tracking-tighter">Lorebook</span>
</div>
<h2 class="font-headline-lg-mobile md:font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface mb-2">Tạo tài khoản mới</h2>
<p class="font-body-md text-body-md text-on-surface-variant">Bắt đầu hành trình lưu trữ cá nhân của bạn ngay hôm nay.</p>
</div>
<form action="#" class="space-y-6" id="registrationForm">
<!-- Name Field -->
<div class="space-y-2">
<label class="font-label-md text-label-md text-on-surface-variant block ml-1" for="full_name">Họ tên</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">person</span>
<input class="w-full input-inset border border-outline-variant rounded-lg py-3.5 pl-12 pr-4 font-body-md text-body-md text-on-surface placeholder:text-on-surface-variant/50" id="full_name" name="full_name" placeholder="Nguyễn Văn A" type="text"/>
</div>
</div>
<!-- Email Field -->
<div class="space-y-2">
<label class="font-label-md text-label-md text-on-surface-variant block ml-1" for="email">Email</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">mail</span>
<input class="w-full input-inset border border-outline-variant rounded-lg py-3.5 pl-12 pr-4 font-body-md text-body-md text-on-surface placeholder:text-on-surface-variant/50" id="email" name="email" placeholder="example@lorebook.com" type="email"/>
</div>
</div>
<!-- Password Fields Row -->
<div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
<div class="space-y-2">
<label class="font-label-md text-label-md text-on-surface-variant block ml-1" for="password">Mật khẩu</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">lock</span>
<input class="w-full input-inset border border-outline-variant rounded-lg py-3.5 pl-12 pr-4 font-body-md text-body-md text-on-surface placeholder:text-on-surface-variant/50" id="password" name="password" placeholder="••••••••" type="password"/>
</div>
</div>
<div class="space-y-2">
<label class="font-label-md text-label-md text-on-surface-variant block ml-1" for="confirm_password">Nhập lại</label>
<div class="relative">
<span class="material-symbols-outlined absolute left-4 top-1/2 -translate-y-1/2 text-on-surface-variant text-[20px]">key</span>
<input class="w-full input-inset border border-outline-variant rounded-lg py-3.5 pl-12 pr-4 font-body-md text-body-md text-on-surface placeholder:text-on-surface-variant/50" id="confirm_password" name="confirm_password" placeholder="••••••••" type="password"/>
</div>
</div>
</div>
<!-- Terms Checkbox -->
<div class="flex items-start gap-3 pt-2">
<div class="relative flex items-center mt-1">
<input class="w-5 h-5 rounded border-outline-variant bg-surface-container-lowest text-primary focus:ring-primary-container focus:ring-offset-background transition-all cursor-pointer" id="terms" name="terms" type="checkbox"/>
</div>
<label class="font-label-sm text-label-sm text-on-surface-variant leading-relaxed cursor-pointer" for="terms">
                        Tôi đồng ý với <a class="text-primary hover:underline transition-all" href="#">Điều khoản sử dụng</a> và <a class="text-primary hover:underline transition-all" href="#">Chính sách bảo mật</a> của Lorebook.
                    </label>
</div>
<!-- Submit Button -->
<button class="w-full bg-primary-container hover:brightness-110 active:scale-[0.98] transition-all text-on-primary-container font-headline-md text-headline-md py-4 rounded-lg shadow-lg shadow-primary-container/10 flex items-center justify-center gap-2 mt-4" type="submit">
                    Đăng ký
                    <span class="material-symbols-outlined">arrow_forward</span>
</button>
</form>
<!-- Footer Link -->
<div class="mt-8 text-center">
<p class="font-label-md text-label-md text-on-surface-variant">
                    Đã có tài khoản? 
                    <a class="text-primary font-bold hover:underline ml-1 inline-flex items-center gap-1 transition-all" href="#">
                        Đăng nhập ngay
                    </a>
</p>
</div>
</section>
</main>
<!-- Micro-interaction Script -->
<script>
        document.addEventListener('DOMContentLoaded', () => {
            const form = document.getElementById('registrationForm');
            const inputs = form.querySelectorAll('input');

            // Add focus/blur effects for parent elements
            inputs.forEach(input => {
                input.addEventListener('focus', () => {
                    input.parentElement.querySelector('.material-symbols-outlined').style.color = '#b7d8b0';
                });
                input.addEventListener('blur', () => {
                    input.parentElement.querySelector('.material-symbols-outlined').style.color = '#c3c8be';
                });
            });

            // Prevent default for demo
            form.addEventListener('submit', (e) => {
                const checkbox = document.getElementById('terms');
                if (!checkbox.checked) {
                    e.preventDefault();
                    checkbox.classList.add('animate-pulse');
                    setTimeout(() => checkbox.classList.remove('animate-pulse'), 1000);
                    alert('Vui lòng đồng ý với điều khoản sử dụng trước khi tiếp tục.');
                    return;
                }
                e.preventDefault();
                console.log('Form submission intercepted for demo.');
            });
        });
    </script>
</body></html>